{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://tradepro-backend-erfj.onrender.com/api/:path*"
    },
    {
      "source": "/((?!api).*)",
      "destination": "/index.html"
    },
    {
      "source": "/(.*)",
      "destination": {
        "type": "service",
        "service": "web"
      }
    }
  ],
  "services": {
    "web": {
      "root": ".",
      "framework": "vite"
    }
  }
}
